{
  "name": "go.server",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/web",
    "packages/admin-console"
  ],
  "scripts": {
    "gen:api": "orval --config openapi/orval.config.ts",
    "dev:web": "bun --filter web dev",
    "dev:admin": "bun --filter admin-console dev",
    "build:web": "bun --filter web build",
    "build:admin": "bun --filter admin-console build",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "orval": "^7.13.2"
  }
}
